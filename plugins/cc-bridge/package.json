{
  "name": "cc-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Bridge Claude Code configuration to Codex CLI",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "cc-bridge": "dist/cli.js",
    "cc-bridge-refresh-cli-docs": "dist/refresh/refresh-cli-docs.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "bridge": "bun run src/cli.ts",
    "refresh-cli-docs": "bun run src/refresh/refresh-cli-docs.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "smol-toml": "^1.3.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/node": "^20.17.10",
    "typescript": "^5.7.2"
  }
}
